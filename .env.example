# Solana RPC (devnet by default)
RPC_URL=https://api.devnet.solana.com

# Path to your Solana keypair JSON (owner wallet)
WALLET_PATH=./keypairs/owner.json

# Path to the executive wallet keypair (off-chain operator)
EXECUTIVE_WALLET_PATH=./keypairs/executive.json

# Funded in previous step — do not commit actual keypairs
